# ============================================
# DATABASE
# ============================================
DATABASE_URL="postgresql://microplanner:microplanner_dev_password@localhost:5432/microplanner_dev"

# ============================================
# REDIS
# ============================================
REDIS_URL="redis://localhost:6379"

# ============================================
# CLERK AUTHENTICATION
# ============================================
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
CLERK_WEBHOOK_SECRET="whsec_..."
# Clerk domain (e.g., "clerk.your-app.com" or "your-clerk-instance.clerk.accounts.dev")
CLERK_DOMAIN="your-clerk-instance.clerk.accounts.dev"
# Clerk audience (optional, usually your API URL)
CLERK_AUDIENCE="http://localhost:3001"

# ============================================
# STRIPE BILLING
# ============================================
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Stripe Price IDs
STRIPE_PRICE_STARTER_MONTHLY="price_..."
STRIPE_PRICE_STARTER_YEARLY="price_..."
STRIPE_PRICE_PRO_MONTHLY="price_..."
STRIPE_PRICE_PRO_YEARLY="price_..."

# ============================================
# OPENAI
# ============================================
OPENAI_API_KEY="sk-..."
OPENAI_ORG_ID="org-..."

# ============================================
# GOOGLE CALENDAR
# ============================================
GOOGLE_CLIENT_ID="..."
GOOGLE_CLIENT_SECRET="..."
GOOGLE_REDIRECT_URI="http://localhost:3001/api/calendar/oauth/google/callback"

# ============================================
# ENCRYPTION
# ============================================
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY="your-32-byte-hex-key-here"

# ============================================
# SENTRY (Error Tracking)
# ============================================
SENTRY_DSN="https://...@sentry.io/..."
SENTRY_AUTH_TOKEN="..."

# ============================================
# POSTHOG (Analytics)
# ============================================
NEXT_PUBLIC_POSTHOG_KEY="phc_..."
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# ============================================
# RESEND (Email)
# ============================================
RESEND_API_KEY="re_..."
# Email "from" address - must use a domain verified in Resend
# Format: "Display Name <email@your-verified-domain.com>"
EMAIL_FROM="MicroPlanner <noreply@yourdomain.com>"

# ============================================
# EXPO (Mobile Push Notifications)
# ============================================
EXPO_ACCESS_TOKEN="..."

# ============================================
# SERVICES
# ============================================
PLANNING_SERVICE_URL="http://localhost:8000"
API_GATEWAY_URL="http://localhost:3001"

# ============================================
# ENVIRONMENT
# ============================================
NODE_ENV="development"
LOG_LEVEL="debug"

# ============================================
# FEATURE FLAGS
# ============================================
ENABLE_AI_MEMORY="false"
ENABLE_TEAM_FEATURES="false"

# ============================================
# APP CONFIGURATION
# ============================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:3001/api"

# ============================================
# ADDED / CORRECTED (billing + admin + AI)
# ============================================
# Comma-separated admin allowlist (refunds, reconciliation, waitlist ops).
# Admin endpoints FAIL CLOSED when unset.
ADMIN_EMAILS=

# Clerk JWKS domain (e.g. your-app.clerk.accounts.dev) — required by BOTH
# api-gateway and graphql-gateway for JWT signature verification.
CLERK_DOMAIN=

# Stripe price IDs — created by: node scripts/setup-stripe-products.mjs
STRIPE_STARTER_PRICE_ID=
STRIPE_PRO_PRICE_ID=
STRIPE_PREMIUM_PRICE_ID=

# Anthropic model for the Pro/Premium planner (default claude-sonnet-5)
ANTHROPIC_PLANNER_MODEL=claude-sonnet-5

# Base URL of the web app (checkout redirects + email links)
APP_URL=http://localhost:3000

# NOTE: packages/database/.env must contain ONLY DATABASE_URL/DIRECT_URL —
# Prisma loads it before app env files and dotenv never overrides.
