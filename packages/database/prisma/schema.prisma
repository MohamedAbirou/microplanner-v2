// MicroPlanner Database Schema
// PostgreSQL with pgvector for AI embeddings

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  extensions = [pgvector(map: "vector")]
}

// ============================================
// USER DOMAIN
// ============================================

model User {
  id                String              @id @default(cuid())
  clerkId           String              @unique
  email             String              @unique
  name              String?
  avatar            String?
  timezone          String              @default("UTC")

  // Subscription
  tier              SubscriptionTier    @default(FREE)
  stripeCustomerId  String?             @unique
  subscriptionId    String?
  subscriptionStatus SubscriptionStatus @default(INACTIVE)

  // Dunning state (billing lifecycle)
  paymentFailedCount Int                @default(0)  // consecutive failed payments
  paymentGraceUntil  DateTime?          // anchored to FIRST failure; never slides forward

  // Embedded preferences (denormalized for performance)
  wakeTime          String              @default("07:00")
  sleepTime         String              @default("23:00")
  workStartTime     String              @default("09:00")
  workEndTime       String              @default("17:00")
  productivityPeaks String[]           @default([])
  energyPattern     EnergyPattern?
  blockedTimes      Json?               // [{day: "monday", start: "12:00", end: "13:00"}]

  // Device tokens for push notifications
  pushTokens        String[]           @default([])

  // Metadata
  onboardingCompleted Boolean          @default(false)
  onboardingStep    Int                @default(0)
  language          String             @default("en")
  context           String?            // User context: employed_fulltime, student, freelancer, etc.
  focusAreas        String[]           @default([]) // Focus areas: career, learning, health, etc.

  // Usage tracking for tier limits enforcement
  activeGoalsCount     Int @default(0)     // Current active goals
  plansCreatedThisWeek Int @default(0)     // Plans created this week
  tasksCreatedToday    Int @default(0)     // Tasks created today
  lastPlanCreatedAt    DateTime?           // Last plan generation timestamp
  weeklyPlanResetAt    DateTime @default(now()) // When to reset weekly plan count
  dailyTaskResetAt     DateTime @default(now()) // When to reset daily task count

  // Relations
  goals             Goal[]
  plans             WeeklyPlan[]
  planTemplates     PlanTemplate[]
  tasks             Task[]
  calendarTokens    CalendarToken[]
  aiMemory          AIMemory[]
  referrals         Referral[]         @relation("ReferredBy")
  referredUsers     Referral[]         @relation("Referrer")
  ownedTeams        Team[]             @relation("TeamOwner")
  teamMemberships   TeamMember[]
  sentInvitations   TeamInvitation[]
  apiKeys           ApiKey[]
  schedulingLinks   SchedulingLink[]
  integrations      Integration[]
  webhooks          Webhook[]
  projects          Project[]

  // Productivity & Work-Life Balance (Phase 18)
  workHours              WorkHours?
  focusTimeBlocks        FocusTimeBlock[]
  noMeetingDays          NoMeetingDay[]
  priorityHours          PriorityHours?
  calendarDefense        CalendarDefense?
  smart1on1s             Smart1on1[]
  travelTimes            TravelTime[]
  kanbanBoards           KanbanBoard[]
  productivityScores     ProductivityScore[]
  smartNotifications     SmartNotification[]
  notificationPreferences NotificationPreferences?

  // Timestamps
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  lastSeenAt        DateTime           @default(now())

  @@index([email])
  @@index([tier])
  @@index([clerkId])
}

enum SubscriptionTier {
  FREE
  STARTER
  PRO
  PREMIUM
}

enum SubscriptionStatus {
  ACTIVE
  INACTIVE
  PAST_DUE
  CANCELED
  TRIALING
}

enum EnergyPattern {
  MORNING_PERSON
  NIGHT_OWL
  BALANCED
}

// ============================================
// GOALS DOMAIN
// ============================================

model Goal {
  id               String       @id @default(cuid())
  userId           String
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Project grouping (Phase 17)
  projectId        String?
  project          Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)

  // Goal details
  title            String
  description      String?
  emoji            String?      @default("🎯")
  color            String?      @default("#3B82F6")

  // Scheduling parameters
  frequencyPerWeek Int          @default(3)
  durationMinutes  Int          @default(60)
  preferredTimes   String[]     @default([]) // ["morning", "evening"]
  flexibilityScore Int          @default(5) // 1-10, how flexible scheduling is

  // Priority & status
  priority         Int          @default(5) // 1-10
  isActive         Boolean      @default(true)
  isPaused         Boolean      @default(false)
  pausedUntil      DateTime?

  // Analytics
  completionRate   Float        @default(0) // 0-100
  totalCompletions Int          @default(0)
  totalScheduled   Int          @default(0)
  currentStreak    Int          @default(0)
  longestStreak    Int          @default(0)
  lastCompletedAt  DateTime?

  // Relations
  tasks            Task[]

  // Timestamps
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([userId, isActive])
  @@index([userId, priority])
  @@index([projectId])
}

// ============================================
// TASKS DOMAIN
// ============================================

model Task {
  id                String       @id @default(cuid())
  userId            String
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  goalId            String?
  goal              Goal?        @relation(fields: [goalId], references: [id], onDelete: Cascade)
  planId            String?
  plan              WeeklyPlan?  @relation(fields: [planId], references: [id], onDelete: SetNull)

  // Advanced task management (Phase 17)
  parentTaskId      String?
  parentTask        Task?        @relation("TaskSubtasks", fields: [parentTaskId], references: [id], onDelete: Cascade)
  subtasks          Task[]       @relation("TaskSubtasks")
  dependencies      TaskDependency[] @relation("DependentTask")
  blockedBy         TaskDependency[] @relation("BlockingTask")
  projectId         String?
  project           Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)

  // Task details
  title             String
  notes             String?
  priority          Int          @default(2) // 1=High, 2=Medium, 3=Low
  tags              String[]     @default([])

  // Scheduling
  scheduledDate     DateTime
  startTime         String       // "09:00"
  endTime           String       // "10:00"
  durationMinutes   Int
  recurrenceRule    Json?        // Recurring task configuration: { frequency, interval, daysOfWeek, etc. }
  recurrenceExceptions Json?     // Array of exceptions: { date, type: "deleted" | "modified", modifications: {...} }

  // Status
  isCompleted       Boolean      @default(false)
  completedAt       DateTime?
  isSkipped         Boolean      @default(false)
  skippedReason     String?
  skippedAt         DateTime?

  // Time tracking (Phase 17)
  actualStartTime   DateTime?    // When user actually started
  actualEndTime     DateTime?    // When user actually finished
  timeSpentMinutes  Int          @default(0) // Actual time tracked
  isTimerRunning    Boolean      @default(false)
  timerStartedAt    DateTime?

  // Source tracking
  aiGenerated       Boolean      @default(true)
  manuallyAdded     Boolean      @default(false)
  manuallyMoved     Boolean      @default(false)
  aiReasoning       String?      // Why AI scheduled at this time

  // Calendar sync
  calendarEventId   String?      @unique
  calendarProvider  String?      // "google" | "outlook"
  syncedAt          DateTime?
  syncStatus        SyncStatus   @default(PENDING)
  syncError         String?

  // Offline support
  localId           String?      @unique // Client-generated UUID
  pendingSync       Boolean      @default(false)
  offlineCreatedAt  DateTime?

  // Timestamps
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([userId, scheduledDate])
  @@index([goalId])
  @@index([planId])
  @@index([syncStatus])
  @@index([localId])
  @@index([isCompleted])
  @@index([parentTaskId])
  @@index([projectId])
  @@index([priority])
}

enum SyncStatus {
  PENDING
  SYNCING
  SYNCED
  FAILED
  CONFLICT
}

// ==================== TASK DEPENDENCIES & PROJECTS (Phase 17) ====================

// Task dependencies (this task depends on another task)
model TaskDependency {
  id              String   @id @default(cuid())

  // The task that is blocked
  dependentTaskId String
  dependentTask   Task     @relation("DependentTask", fields: [dependentTaskId], references: [id], onDelete: Cascade)

  // The task that must be completed first
  blockingTaskId  String
  blockingTask    Task     @relation("BlockingTask", fields: [blockingTaskId], references: [id], onDelete: Cascade)

  // Dependency type
  type            String   @default("BLOCKS") // BLOCKS, BLOCKED_BY, RELATED_TO

  // Timestamps
  createdAt       DateTime @default(now())

  @@unique([dependentTaskId, blockingTaskId])
  @@index([dependentTaskId])
  @@index([blockingTaskId])
}

// Projects (grouping tasks into projects)
model Project {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Project details
  name            String
  description     String?
  color           String   @default("#3B82F6")
  icon            String?

  // Status
  isArchived      Boolean  @default(false)
  archivedAt      DateTime?

  // Dates
  startDate       DateTime?
  targetDate      DateTime?
  completedAt     DateTime?

  // Relations
  tasks           Task[]
  goals           Goal[]
  kanbanBoards    KanbanBoard[]

  // Timestamps
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([isArchived])
}

// ============================================
// PLANS DOMAIN
// ============================================

model WeeklyPlan {
  id              String       @id @default(cuid())
  userId          String
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Plan timing
  weekStartDate   DateTime     // Always Monday 00:00
  weekEndDate     DateTime     // Always Sunday 23:59

  // Plan data
  planJson        Json         // Full structured plan
  reasoning       Json?        // AI's reasoning for each task

  // Status
  status          PlanStatus   @default(DRAFT)
  acceptedAt      DateTime?
  appliedAt       DateTime?    // When synced to calendar
  archivedAt      DateTime?

  // AI metadata
  aiModel         String?      // "gpt-4o-mini" | "gpt-4o" | "rule-based"
  complexity      String?      // "simple" | "standard" | "complex"
  generationTime  Float?       // seconds
  generationCost  Float?       // USD cents
  tokenUsage      Int?

  // Quality metrics
  qualityScore    Float?       // 0-100
  userSatisfaction String?     // "accepted" | "edited" | "rejected" | "regenerated"
  editCount       Int          @default(0)
  regenerateCount Int          @default(0)

  // Analytics
  completionRate  Float        @default(0) // 0-100
  totalTasks      Int          @default(0)
  completedTasks  Int          @default(0)

  // Relations
  tasks           Task[]

  // Timestamps
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([userId, weekStartDate])
  @@index([status])
  @@index([weekStartDate])
}

enum PlanStatus {
  DRAFT
  ACCEPTED
  APPLIED
  ARCHIVED
}

// Plan Templates (PRO/PREMIUM feature)
model PlanTemplate {
  id                  String   @id @default(cuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Template metadata
  name                String
  description         String?
  category            String   @default("custom")
  isPublic            Boolean  @default(false)
  isDefault           Boolean  @default(false)
  usageCount          Int      @default(0)
  tags                String[] @default([])

  // Template data
  tasks               Json     // Array of TemplateTask objects
  estimatedTotalHours Float    @default(0)
  tasksPerDay         Json     // Record<dayOfWeek, taskCount>

  // Timestamps
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([userId])
  @@index([isPublic])
  @@index([category])
}

// ============================================
// AI MEMORY DOMAIN (Post-MVP)
// ============================================

model AIMemory {
  id              String       @id @default(cuid())
  userId          String
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Memory details
  memoryType      MemoryType
  content         Json         // Flexible JSON structure

  // Metadata
  confidence      Float        @default(0.5) // 0-1
  useCount        Int          @default(0)
  lastUsedAt      DateTime?
  source          String?      // Which plan/interaction created this

  // Timestamps
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([userId, memoryType])
  @@index([userId, confidence])
}

enum MemoryType {
  TIME_PREFERENCE      // "User prefers gym at 7am"
  COMPLETION_PATTERN   // "User completes 90% of morning tasks"
  ENERGY_INSIGHT       // "Most productive on Tuesdays"
  AVOIDANCE_PATTERN    // "User always skips evening workouts"
  CONTEXT_PREFERENCE   // "User needs 2-hour focus blocks for coding"
}

// ============================================
// CALENDAR DOMAIN
// ============================================

model CalendarToken {
  id           String       @id @default(cuid())
  userId       String
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Provider
  provider     String       // "google" | "outlook" | "apple"

  // OAuth tokens (encrypted at application level before storing)
  accessToken  String       @db.Text
  refreshToken String?      @db.Text
  expiresAt    DateTime?

  // Calendar metadata
  calendarId   String?      // Primary calendar ID
  calendarName String?
  email        String?      // Calendar account email

  // Sync state
  lastSyncAt   DateTime?
  syncEnabled  Boolean      @default(true)
  syncErrors   Int          @default(0)
  lastError    String?

  // Timestamps
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@unique([userId, provider])
  @@index([userId])
  @@index([provider])
}

model SyncLog {
  id              String       @id @default(cuid())
  userId          String
  planId          String?

  // Sync details
  syncType        String       // "full" | "partial" | "rollback"
  tasksAttempted  Int
  tasksSucceeded  Int
  tasksFailed     Int

  // Results
  success         Boolean
  errors          Json?        // Array of error objects
  duration        Int          // milliseconds

  // Timestamp
  createdAt       DateTime     @default(now())

  @@index([userId])
  @@index([planId])
  @@index([createdAt])
}

// ============================================
// ANALYTICS DOMAIN
// ============================================

model AnalyticsEvent {
  id         String       @id @default(cuid())
  userId     String?
  sessionId  String?

  // Event details
  event      String       // "plan_generated", "task_completed", etc.
  properties Json?

  // Context
  platform   String?      // "ios" | "android" | "web"
  appVersion String?
  userTier   String?

  // Timestamp
  timestamp  DateTime     @default(now())

  @@index([userId])
  @@index([event])
  @@index([timestamp])
  @@index([platform])
}

model LLMUsage {
  id             String       @id @default(cuid())
  userId         String?
  planId         String?

  // LLM details
  model          String       // "gpt-4o-mini" | "gpt-4o"
  operation      String       // "plan_generation" | "chat"

  // Token usage
  inputTokens    Int
  outputTokens   Int
  totalTokens    Int
  cost           Float        // USD cents

  // Performance
  latency        Float        // seconds
  success        Boolean      @default(true)
  errorMessage   String?

  // Timestamp
  timestamp      DateTime     @default(now())

  @@index([userId])
  @@index([model])
  @@index([timestamp])
}

// ============================================
// REFERRALS DOMAIN
// ============================================

model Referral {
  id          String       @id @default(cuid())
  referrerId  String
  referrer    User         @relation("Referrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referredId  String
  referred    User         @relation("ReferredBy", fields: [referredId], references: [id], onDelete: Cascade)

  // Status
  status      ReferralStatus @default(PENDING)
  rewardGranted Boolean    @default(false)

  // Metadata
  referralCode String?
  source      String?      // "link" | "email" | "social"

  // Timestamps
  createdAt   DateTime     @default(now())
  completedAt DateTime?

  @@unique([referrerId, referredId])
  @@index([referrerId])
  @@index([referredId])
  @@index([status])
}

enum ReferralStatus {
  PENDING    // Signed up, not subscribed yet
  ACTIVE     // Subscribed, both users get reward
  EXPIRED    // Never subscribed
}

// ============================================
// ADMIN & SYSTEM
// ============================================

model InviteCode {
  id         String       @id @default(cuid())
  code       String       @unique
  maxUses    Int          @default(1)
  usedCount  Int          @default(0)
  createdBy  String?      // Admin user ID or null for system
  expiresAt  DateTime?

  // Metadata
  source     String?      // "beta" | "referral" | "influencer"
  notes      String?

  // Timestamps
  createdAt  DateTime     @default(now())

  @@index([code])
  @@index([expiresAt])
}

model SystemConfig {
  id        String       @id @default(cuid())
  key       String       @unique
  value     Json

  // Metadata
  description String?
  updatedBy String?

  // Timestamps
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([key])
}

// ============================================
// PREMIUM FEATURES
// ============================================

// Team Workspace (PREMIUM tier)
model Team {
  id          String         @id @default(cuid())
  name        String
  description String?
  ownerId     String
  owner       User           @relation("TeamOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  // Team plan
  plan        String         @default("premium") // "premium" | "enterprise"
  maxMembers  Int            @default(10)
  logoUrl     String?

  // Settings
  settings    Json           // TeamSettings object

  // Relations
  members     TeamMember[]
  invitations TeamInvitation[]

  // Timestamps
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([ownerId])
  @@index([plan])
}

model TeamMember {
  id        String   @id @default(cuid())
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Member details
  role      String   @default("member") // "owner" | "admin" | "member" | "viewer"
  status    String   @default("active") // "active" | "invited" | "suspended"
  invitedBy String?

  // Timestamps
  joinedAt  DateTime @default(now())

  @@unique([teamId, userId])
  @@index([teamId])
  @@index([userId])
  @@index([status])
}

model TeamInvitation {
  id         String    @id @default(cuid())
  teamId     String
  team       Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  email      String
  role       String    @default("member")
  invitedBy  String
  inviter    User      @relation(fields: [invitedBy], references: [id], onDelete: Cascade)
  token      String    @unique
  expiresAt  DateTime
  acceptedAt DateTime?

  // Timestamps
  createdAt  DateTime  @default(now())

  @@index([teamId])
  @@index([email])
  @@index([token])
  @@index([expiresAt])
}

// API Access (PREMIUM tier)
model ApiKey {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Key details
  name        String
  key         String    @unique // Hashed
  keyPrefix   String    // First 8 chars for display

  // Permissions
  scopes      String[]  // Array of ApiScope
  rateLimit   Int       @default(1000) // Requests per hour

  // Usage tracking
  usageCount  Int       @default(0)
  lastUsedAt  DateTime?

  // Status
  isActive    Boolean   @default(true)
  expiresAt   DateTime?

  // Timestamps
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId])
  @@index([key])
  @@index([keyPrefix])
  @@index([isActive])
  @@index([expiresAt])
}

// ============================================
// SCHEDULING LINKS (PREMIUM FEATURE)
// ============================================

// Scheduling Link (Calendly-like)
model SchedulingLink {
  id                    String    @id @default(cuid())
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Link details
  name                  String
  slug                  String    @unique
  description           String?
  duration              Int       // Minutes
  bufferBefore          Int       @default(0)
  bufferAfter           Int       @default(0)
  meetingType           String    @default("one-on-one")
  location              String?
  color                 String    @default("#3B82F6")

  // Settings
  isActive              Boolean   @default(true)
  isPublic              Boolean   @default(true)
  requiresConfirmation  Boolean   @default(false)
  maxBookingsPerDay     Int?
  noticeTime            Int       @default(24) // Hours

  // Availability & customization
  availability          Json      // AvailabilitySettings
  customQuestions       Json      @default("[]")
  redirectUrl           String?
  confirmationMessage   String?

  // Stats
  bookingCount          Int       @default(0)

  // Relations
  bookings              Booking[]

  // Timestamps
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@index([slug])
  @@index([isActive])
  @@index([isPublic])
}

// Booking
model Booking {
  id                String         @id @default(cuid())
  linkId            String
  link              SchedulingLink @relation(fields: [linkId], references: [id], onDelete: Cascade)

  // Attendee details
  attendeeName      String
  attendeeEmail     String
  attendeePhone     String?

  // Booking time
  startTime         DateTime
  endTime           DateTime
  timezone          String

  // Status
  status            String         @default("pending") // "pending" | "confirmed" | "canceled" | "completed"
  canceledAt        DateTime?
  cancelReason      String?

  // Custom responses
  customResponses   Json           @default("{}")

  // Meeting details
  meetingUrl        String?
  calendarEventId   String?
  reminderSent      Boolean        @default(false)

  // Timestamps
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([linkId])
  @@index([attendeeEmail])
  @@index([startTime])
  @@index([status])
}

// ==================== INTEGRATIONS ====================

// Third-party integrations (Slack, Zoom, Notion, etc.)
model Integration {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Integration details
  type          String   // slack, zoom, google-meet, notion, linear, github
  name          String
  isActive      Boolean  @default(true)

  // Configuration
  config        Json     @default("{}") // Type-specific configuration
  credentials   Json     @default("{}") // Encrypted OAuth tokens
  metadata      Json     @default("{}") // Additional data

  // Sync tracking
  lastSyncAt    DateTime?

  // Timestamps
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([type])
  @@index([isActive])
}

// Webhooks for external event notifications
model Webhook {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Webhook details
  url             String
  events          String[] // Array of event types
  secret          String   // For signature verification
  isActive        Boolean  @default(true)

  // Delivery tracking
  lastTriggeredAt DateTime?
  failureCount    Int      @default(0)

  // Timestamps
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  deliveries      WebhookDelivery[]

  @@index([userId])
  @@index([isActive])
}

// Webhook delivery log
model WebhookDelivery {
  id            String   @id @default(cuid())
  webhookId     String
  webhook       Webhook  @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  // Delivery details
  event         String
  payload       Json
  status        String   // pending, success, failed
  statusCode    Int?
  responseBody  String?
  error         String?

  // Retry tracking
  attempts      Int      @default(0)
  lastAttemptAt DateTime?

  // Timestamps
  createdAt     DateTime @default(now())

  @@index([webhookId])
  @@index([status])
  @@index([createdAt])
}

// ==================== PRODUCTIVITY & WORK-LIFE BALANCE (Phase 18) ====================

// Work hours configuration
model WorkHours {
  id                      String   @id @default(cuid())
  userId                  String   @unique
  user                    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  timezone                String   @default("UTC")

  // Weekly schedule (stored as JSON for flexibility)
  schedule                Json     // { monday: {...}, tuesday: {...}, etc. }

  // Work-life balance rules
  enforceWorkHours        Boolean  @default(true)
  maxMeetingsPerDay       Int?
  maxMeetingHoursPerDay   Int?
  maxConsecutiveMeetings  Int?

  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([userId])
}

// Focus time blocks
model FocusTimeBlock {
  id                  String   @id @default(cuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  title               String
  frequency           String   // daily, weekdays, weekly, custom
  daysOfWeek          Int[]    // [1,2,3,4,5] for weekdays
  startTime           String?  // "09:00" or null if autoSchedule
  durationMinutes     Int

  priority            Int      @default(5)
  protected           Boolean  @default(true)
  isActive            Boolean  @default(true)
  autoSchedule        Boolean  @default(false)
  preferredTimeSlots  String[] @default([])

  color               String   @default("#3B82F6")

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([userId])
  @@index([isActive])
}

// No-meeting days
model NoMeetingDay {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  dayOfWeek       Int      // 0=Sunday, 1=Monday, etc.
  isActive        Boolean  @default(true)
  allowExceptions Boolean  @default(false)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([userId, dayOfWeek])
  @@index([userId])
}

// Priority hours
model PriorityHours {
  id                    String   @id @default(cuid())
  userId                String   @unique
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  timeSlots             Json     // Array of { dayOfWeek, startTime, endTime, priority }
  prioritizeFocusTime   Boolean  @default(true)
  prioritizeTasks       Boolean  @default(true)
  deprioritizeMeetings  Boolean  @default(true)

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([userId])
}

// Calendar defense rules
model CalendarDefense {
  id                            String   @id @default(cuid())
  userId                        String   @unique
  user                          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  autoAcceptDuringOpenHours     Boolean  @default(false)
  autoDeclineDuringFocusTime    Boolean  @default(true)
  autoDeclineOutsideWorkHours   Boolean  @default(true)
  autoDeclineDoubleBookings     Boolean  @default(true)

  requireMinimumNotice          Boolean  @default(true)
  minimumNoticeHours            Int      @default(24)

  requireBufferBetweenMeetings  Boolean  @default(true)
  bufferMinutes                 Int      @default(15)

  suggestShorterMeetings        Boolean  @default(true)
  defaultMeetingDuration        Int      @default(30)

  createdAt                     DateTime @default(now())
  updatedAt                     DateTime @updatedAt

  @@index([userId])
}

// Smart 1:1 scheduling
model Smart1on1 {
  id                      String    @id @default(cuid())
  userId                  String
  user                    User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  personName              String
  personEmail             String
  frequency               String    // weekly, biweekly, monthly
  durationMinutes         Int       @default(30)

  autoSchedule            Boolean   @default(true)
  autoRescheduleOnConflict Boolean  @default(true)
  preferredDays           Int[]     @default([])
  preferredTimes          String[]  @default([])

  isActive                Boolean   @default(true)
  lastScheduledDate       DateTime?
  nextScheduledDate       DateTime?

  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  @@index([userId])
  @@index([isActive])
}

// Travel time entries
model TravelTime {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  fromEventId       String
  toEventId         String
  estimatedMinutes  Int
  method            String   // driving, walking, transit, auto

  createdAt         DateTime @default(now())

  @@index([userId])
  @@index([fromEventId])
  @@index([toEventId])
}

// Kanban boards
model KanbanBoard {
  id          String         @id @default(cuid())
  userId      String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId   String?
  project     Project?       @relation(fields: [projectId], references: [id], onDelete: SetNull)

  name        String
  description String?
  isDefault   Boolean        @default(false)

  columns     KanbanColumn[]

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([userId])
  @@index([projectId])
}

// Kanban columns
model KanbanColumn {
  id       String      @id @default(cuid())
  boardId  String
  board    KanbanBoard @relation(fields: [boardId], references: [id], onDelete: Cascade)

  name     String
  order    Int
  color    String      @default("#3B82F6")
  taskIds  String[]    @default([])

  @@index([boardId])
}

// Productivity scores (daily)
model ProductivityScore {
  id                      String   @id @default(cuid())
  userId                  String
  user                    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date                    DateTime

  overallScore            Int      // 0-100
  focusTimeScore          Int
  taskCompletionScore     Int
  meetingEfficiencyScore  Int
  workLifeBalanceScore    Int

  totalFocusMinutes       Int
  totalMeetingMinutes     Int
  totalTaskMinutes        Int
  totalBreakMinutes       Int

  insights                String[]
  recommendations         String[]

  createdAt               DateTime @default(now())

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
}

// Smart notifications
model SmartNotification {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  type       String   // NotificationType enum
  title      String
  message    String
  priority   String   @default("medium") // low, medium, high, urgent
  actionUrl  String?
  isRead     Boolean  @default(false)

  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

// Notification preferences
model NotificationPreferences {
  id                    String   @id @default(cuid())
  userId                String   @unique
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  emailEnabled          Boolean  @default(true)
  pushEnabled           Boolean  @default(true)
  smsEnabled            Boolean  @default(false)

  overbookedAlerts      Boolean  @default(true)
  breakReminders        Boolean  @default(true)
  focusTimeAlerts       Boolean  @default(true)
  upcomingMeetingAlerts Boolean  @default(true)
  taskDueAlerts         Boolean  @default(true)
  weeklySummary         Boolean  @default(true)

  quietHoursStart       String   @default("22:00")
  quietHoursEnd         String   @default("08:00")

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([userId])
}
