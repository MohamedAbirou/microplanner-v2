# Server
PORT=4000
NODE_ENV=development

# REST API Gateway (NestJS — no /graphql suffix)
API_GATEWAY_URL=http://localhost:3001
NEST_GRAPHQL_URL=http://localhost:3001/graphql

# Redis (use REDIS_URL on Render, or host/port locally)
REDIS_URL=
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT (Clerk) — required in production
CLERK_DOMAIN=your-instance.clerk.accounts.dev

# CORS — production frontend origin(s)
FRONTEND_URL=http://localhost:3000
# ALLOWED_ORIGINS=https://microplanner-web.vercel.app,https://www.yourdomain.com
