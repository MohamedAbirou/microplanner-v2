{
  "name": "@microplanner/graphql-gateway",
  "version": "1.0.0",
  "description": "GraphQL Gateway for MicroPlanner - Apollo Server 4",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "pnpm codegen && tsc && node scripts/prepare-deploy.js",
    "start": "node dist/index.js",
    "codegen": "graphql-codegen --config codegen.ts",
    "type-check": "pnpm codegen && tsc --noEmit",
    "test": "jest"
  },
  "dependencies": {
    "@apollo/server": "^4.10.0",
    "@apollo/subgraph": "^2.7.0",
    "@apollo/utils.keyvaluecache": "^3.1.0",
    "@graphql-tools/schema": "^10.0.34",
    "@types/express": "^4.17.21",
    "axios": "^1.6.5",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dataloader": "^2.2.2",
    "dotenv": "^16.4.1",
    "express": "^5.1.0",
    "graphql": "^16.8.1",
    "graphql-redis-subscriptions": "^2.6.0",
    "graphql-tag": "^2.12.6",
    "graphql-ws": "^5.16.2",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "jwks-rsa": "^3.1.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^5.0.0",
    "@graphql-codegen/typescript": "^4.0.1",
    "@graphql-codegen/typescript-resolvers": "^4.0.1",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.19",
    "@types/node": "^20.11.5",
    "@types/ws": "^8.18.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
