# ============================================
# MINIMAL DOCKER DEPLOYMENT FOR WAITLIST
# ============================================
# This configuration is for a minimal deployment with just the waitlist feature.
# Redis is optional - the app will run without it (caching and job queues disabled).

# ============================================
# REQUIRED: DATABASE
# ============================================
# Replace with your production database URL
DATABASE_URL="postgresql://user:password@your-db-host:5432/microplanner"

# ============================================
# OPTIONAL: REDIS (for caching & job queues)
# ============================================
# If Redis is not available, the app will run without caching
# Uncomment and configure if you have Redis available:
# REDIS_URL="redis://your-redis-host:6379"
# OR use separate host/port:
# REDIS_HOST="your-redis-host"
# REDIS_PORT="6379"
# REDIS_PASSWORD="your-redis-password"

# ============================================
# APPLICATION
# ============================================
NODE_ENV="production"
PORT="3001"

# ============================================
# OPTIONAL: AUTHENTICATION (Clerk)
# ============================================
# Only needed if you want to protect the waitlist API
# CLERK_SECRET_KEY="sk_live_..."
# CLERK_DOMAIN="your-clerk-instance.clerk.accounts.dev"

# ============================================
# OPTIONAL: ERROR TRACKING (Sentry)
# ============================================
# SENTRY_DSN="https://...@sentry.io/..."
