{
  "version": 2,
  "buildCommand": "(cd ../.. && pnpm install) && pnpm build",
  "installCommand": "echo 'Skip'",
  "devCommand": "pnpm dev",
  "outputDirectory": ".",
  "functions": {
    "dist/main.js": {
      "runtime": "nodejs20.x",
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/dist/main.js"
    }
  ]
}
