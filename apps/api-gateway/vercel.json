{
  "version": 2,
  "installCommand": "cd ../.. && pnpm install",
  "buildCommand": "pnpm build",
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "dist/**",
          "../../node_modules/.prisma/**",
          "../../node_modules/@prisma/**",
          "../../packages/database/prisma/schema.prisma"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/index.ts"
    }
  ]
}
