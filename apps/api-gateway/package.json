{
  "name": "@microplanner/api-gateway",
  "version": "1.0.0",
  "description": "MicroPlanner API Gateway - NestJS",
  "private": true,
  "scripts": {
    "build": "nest build && node scripts/prepare-deploy.js",
    "dev": "cross-env NODE_OPTIONS=--max-old-space-size=8192 nest start --watch",
    "start": "node dist/main.js",
    "start:dev": "cross-env NODE_OPTIONS=--max-old-space-size=8192 nest start --watch",
    "start:debug": "cross-env NODE_OPTIONS=--max-old-space-size=8192 nest start --debug --watch",
    "start:prod": "node dist/main.js",
    "vercel-build": "nest build && node scripts/prepare-deploy.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.20.0",
    "@apollo/server": "^4.10.0",
    "@as-integrations/express5": "^1.0.0",
    "@microplanner/config": "workspace:*",
    "@microplanner/database": "workspace:*",
    "@microplanner/types": "workspace:*",
    "@nestjs/apollo": "^13.2.1",
    "@nestjs/axios": "^3.0.1",
    "@nestjs/bull": "^10.0.1",
    "@nestjs/cli": "^10.3.0",
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.1.1",
    "@nestjs/core": "^10.3.0",
    "@nestjs/graphql": "^13.2.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/schedule": "^6.0.1",
    "@nestjs/swagger": "^7.1.17",
    "@nestjs/terminus": "^11.0.0",
    "@nestjs/throttler": "^5.2.0",
    "@sentry/node": "^10.23.0",
    "@sentry/profiling-node": "^10.23.0",
    "@types/compression": "^1.7.5",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.11.5",
    "@types/passport-jwt": "^4.0.0",
    "axios": "^1.6.5",
    "bull": "^4.12.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "compression": "^1.8.1",
    "googleapis": "^165.0.0",
    "graphql": "^16.8.1",
    "helmet": "^7.2.0",
    "ioredis": "^5.3.2",
    "jwks-rsa": "^3.1.0",
    "nest-winston": "^1.9.4",
    "openai": "^6.8.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "redis": "^4.6.11",
    "reflect-metadata": "^0.2.1",
    "resend": "^6.4.2",
    "rxjs": "^7.8.1",
    "stripe": "^19.3.0",
    "svix": "^1.81.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.3",
    "webpack-node-externals": "^3.0.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@nestjs/schematics": "^10.1.0",
    "@nestjs/testing": "^10.3.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "cross-env": "^10.1.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "jest": "^29.7.0",
    "prettier": "^3.2.4",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0"
  }
